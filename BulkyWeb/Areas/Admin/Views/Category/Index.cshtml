@model List<Category>

<div class="card shadow border-0 mt-4">
	<div class="card-header bg-secondary bg-gradient ml-0 py-3">
		<div class="row">
			<div class="col-12 text-center">
				<h2 class="text-white py-2">Category List</h2>
			</div>
		</div>
	</div>
	<div class="card-body p-4">
		<div class="row pt-4 pb-3">
			<div class="col-12 text-end">
				<a asp-controller="Category" asp-action="Create" class="btn btn-primary">
					<i class="bi bi-plus-square"></i> Create New Category
				</a>
			</div>

		</div>

		<table class="table table-bordered table-striped border border-1">
			<thead>
				<tr>
					<th class="border-1">
						Category Name
					</th>
					<th class="border-1">
						Display Order
					</th>
					<th class="border-1">

					</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var item in Model.OrderBy(C => C.DisplayOrder))
				{
					<tr>
						<td class="border-1">@item.Name</td>
						<td class="border-1">@item.DisplayOrder</td>
						<td class="border-1">
							<div class="w-75 btn-group" role="group">
								<a asp-controller="Category" asp-action="Edit" asp-route-id="@item.ID" class="btn btn-primary mx-2">
									<i class="bi bi-pencil-square"></i>Edit
								</a>
								<a asp-controller="Category" asp-action="Delete" asp-route-id="@item.ID" class="btn btn-danger mx-2">
									<i class="bi bi-trash3"></i>Delete
								</a>
							</div>
						</td>

					</tr>
				}

			</tbody>

		</table>
	</div>
</div>

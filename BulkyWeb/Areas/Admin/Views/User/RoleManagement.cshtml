@model RoleManagementVM

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Manage User Role</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form method="post">
            <input asp-for="ApplicationUser.Id" hidden />
            <div class="border border-1 p-3 mt-4">

                @* 		<div asp-validation-summary="ModelOnly"></div>
 *@		<div class="form-floating py-2 col-12">
                <input asp-for="ApplicationUser.Name" class="form-control border-0 shadow"readonly />
                <label asp-for="ApplicationUser.Name" class="ms-2"></label>
            </div>
            <div class="form-floating mb-3 col-md-6">
                <select asp-for="ApplicationUser.Role" asp-items="@Model.RolesList" class="form-select">
                </select>
                
            </div>
            <div class="form-floating mb-3 col-md-6">
                <select asp-for="ApplicationUser.CompanyID" asp-items="@Model.CompaniesList" class="form-select">
                </select>
                
            </div>
                    

            <div class="row mt-3">
                <div class="col-6">
                    <button type="submit" class="btn btn-primary form-control">Update</button>
                </div>
                <div class="col-6">
                    <a asp-controller="User" asp-action="Index" class="btn btn-outline-secondary border-2 form-control">Back To List</a>
                </div>
            </div>
        </div>

    </form>
</div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() 
        {
            function ShowHideCompaniesList() 
            {
                
                    var selection = $('#ApplicationUser_Role option:selected').text().trim();
                    if (selection == 'Company') {
                    $('#ApplicationUser_CompanyID').show();
                    }
                    else {
                    $('#ApplicationUser_CompanyID').hide();
                    }
            }
            ShowHideCompaniesList();

            $('#ApplicationUser_Role').change(function() {
                ShowHideCompaniesList();
            })


        })
    </script>
}
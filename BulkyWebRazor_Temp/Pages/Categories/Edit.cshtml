@page
@model BulkyWebRazor_Temp.Pages.Categories.EditModel

<form method="post">
	<input type="hidden" asp-for="EditedCategory.ID" />
	<div class="border border-1 p-3 mt-4">
		<div class="row pb-2">
			<h2 class="text-primary">Edit Category</h2>
			<hr class="border-1" />
		</div>
		@* 		<div asp-validation-summary="ModelOnly"></div>
 *@		<div class="mb-3 row p-1">
			<label asp-for="EditedCategory.Name" class="p-0"></label>
			<input asp-for="EditedCategory.Name" class="form-control" />
			<span class="text-danger" asp-validation-for="EditedCategory.Name"></span>
		</div>
		<div class="mb-3 row p-1">
			<label asp-for="EditedCategory.DisplayOrder" class="p-0"></label>
			<input asp-for="EditedCategory.DisplayOrder" class="form-control" />
			<span class="text-danger" asp-validation-for="EditedCategory.DisplayOrder"></span>
		</div>
		<div class="row">
			<div class="col-6">
				<button type="submit" class="btn btn-primary form-control">Update</button>
			</div>
			<div class="col-6">
				<a asp-page="/Categories/Index" class="btn btn-outline-secondary border-2 form-control">Back To List</a>
			</div>
		</div>
	</div>

</form>

@section Scripts
{
	<partial name="_ValidationScriptsPartial" />
}

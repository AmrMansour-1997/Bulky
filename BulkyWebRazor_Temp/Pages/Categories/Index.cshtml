@page
@model BulkyWebRazor_Temp.Pages.Categories.IndexModel


<div class="container">
	<div class="row pt-4 pb-3">
		<div class="col-6 text-start">
			<h2 class="text-primary">Category List</h2>
		</div>
		<div class="col-6 text-end">
			<a asp-page="/Categories/Create" class="btn btn-primary">
				<i class="bi bi-plus-square"></i> Create New Category
			</a>
		</div>

	</div>

	<table class="table table-bordered table-striped border border-1">
		<thead>
			<tr>
				<th class="border-1">
					Category Name
				</th>
				<th class="border-1">
					Display Order
				</th>
				<th class="border-1">

				</th>
			</tr>
		</thead>
		<tbody>
			@foreach (var item in Model.CategoriesList.OrderBy(C => C.DisplayOrder))
			{
				<tr>
					<td class="border-1">@item.Name</td>
					<td class="border-1">@item.DisplayOrder</td>
					<td class="border-1">
						<div class="w-75 btn-group" role="group">
							<a asp-page="/Categories/Edit" asp-route-id="@item.ID" class="btn btn-primary mx-2">
								<i class="bi bi-pencil-square"></i>Edit
							</a>
							<a asp-page="/Categories/Delete" asp-route-id="@item.ID" class="btn btn-danger mx-2">
								<i class="bi bi-trash3"></i>Delete
							</a>
						</div>
					</td>

				</tr>
			}

		</tbody>

	</table>

</div>
